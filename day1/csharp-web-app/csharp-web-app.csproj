<Project Sdk="Microsoft.NET.Sdk.Web">

  <!--
    .csproj คือ Dependency File ของ C#
    SDK="Microsoft.NET.Sdk.Web" = บอกว่าโปรเจกต์นี้เป็น Web App
    ใช้ library ในตัวของ .NET เท่านั้น ไม่ต้องติดตั้ง NuGet package เพิ่ม
  -->

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

</Project>
